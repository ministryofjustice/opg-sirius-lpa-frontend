{{ define "siriusHeader" }}
    <header class="sirius-header" data-module="header">
        <div class="govuk-width-container">
            <div class="sirius-header__inner">
                <div class="sirius-header__primary">
                    <div class="sirius-header__actions">
                        {{ template "header-button" headerBarButton "Back to timeline" (sirius (printf "/lpa/person/%d/%s" .DonorID .SelectedCaseIds)) "icon-backtotimeline" }}
                    </div>
                    <h1 aria-live="polite">
                        {{- .Person.Firstname -}}
                        {{- if .Person.Middlenames }} {{ .Person.Middlenames }}{{ end }}
                        {{- " " -}}{{ .Person.Surname }}
                        <span class="light">{{ .Person.PersonType }}</span>
                    </h1>
                    <div class="sirius-header__actions">
                        {{ template "header-button" headerBarButton "Documents associated to this case" (prefix (printf "/donor/%d/documents%s" .DonorID .CaseUids)) "icon-office-copy" }}
                        {{ template "header-dropdown-button" headerBarButton "Case Information" (prefix "/sirius-header-case-info" ) "icon-caseinfo" }}
                        {{ if and .HasV1PersonsGetPermission (eq (len .SelectedCases) 1) }}
                            {{ with index .SelectedCases 0 }}
                                {{ template "header-dropdown-button" headerBarButton "Details on the people involved in this case" (prefix (printf "/sirius-header-people-info?id=%d" .ID)) "icon-caseperson" }}
                            {{ end }}
                        {{ end }}
                        {{ template "header-dropdown-button" headerBarButton "Calendars" (prefix "/sirius-header-calendars") "calendar-open" }}
                    </div>
                </div>
                <div class="sirius-header__search" data-header-search-slot></div>
            </div>
        </div>
    </header>
{{ end }}