{{ define "page" }}

<div class="action-panel__form">
    {{ template "error-summary" .Error }}

    {{ if .Success }}
        <span class="govuk-!-display-none"
              hx-get="{{ prefix (printf "/action-panel?donorId=%d&entity=%s%s" .DonorID .EntityType .CaseUIDs) }}"
              hx-target=".action-panel__content"
              hx-swap="innerHTML"
              hx-trigger="load"
        ></span>
        {{ template "success-banner" "You have successfully allocated a case." }}
    {{ end }}


    <h1 class="govuk-heading-m">Allocate Cases</h1>

    <p class="govuk-body">
        {{ range .Entities }}
            <strong>{{ . }}</strong>
            <br/>
        {{ end }}
    </p>

    <form class="form" method="POST"
          hx-post="{{ prefix (printf "/allocate-cases?id=%d&entity=%s%s" .CaseID .EntityType .CaseUIDs) }}"
          hx-target=".action-panel__content"
          hx-swap="innerHTML">


            {{ if eq 1 (len .Entities) }}
                <h1 class="govuk-heading-m app-!-embedded-hide">Allocate Case</h1>
            {{ else }}
                <h1 class="govuk-heading-m app-!-embedded-hide">Allocate {{ len .Entities }} Cases</h1>
            {{ end }}

        <input type="hidden" name="xsrfToken" value="{{ .XSRFToken }}"/>
        {{ range .CaseIDs }}
            <input type="hidden" name="id" value="{{ . }}"/>
        {{ end }}

        {{ template "allocate-cases" . }}

        <div class="govuk-button-group">
            <button class="govuk-button" data-module="govuk-button" type="submit">Allocate</button>
            <a class="govuk-link govuk-link--no-visited-state"
               href=""
               hx-get="{{ prefix (printf "/action-panel?donorId=%d&entity=%s%s" .DonorID .EntityType .CaseUIDs) }}"
               hx-target=".action-panel__content"
               hx-swap="innerHTML">Cancel</a>
        </div>

    </form>

    </div>
{{ end }}
